<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PDF to HTML — Book Tools</title>
  <style>
    /* ── Reset & Base ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #1a1a2e;
      --ink-soft:  #3d3d5c;
      --page:      #faf9f6;
      --cream:     #f3f0e8;
      --gold:      #c9a84c;
      --gold-lt:   #e8d5a0;
      --teal:      #2d7d9a;
      --teal-lt:   #d4eef6;
      --rose:      #9b4f72;
      --rose-lt:   #f5dce9;
      --border:    #e2ddd4;
      --shadow:    rgba(26,26,46,.10);
      --radius:    14px;
      --font:      'Georgia', 'Times New Roman', serif;
      --sans:      system-ui, -apple-system, 'Segoe UI', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--page);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 128px;
      opacity: .5;
    }

    .container { max-width: 760px; margin: 0 auto; padding: 0 24px; }

    /* ── NAV ────────────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(16px) saturate(180%);
      background: rgba(250,249,246,.88);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      gap: 24px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--ink);
    }

    .nav-logo-icon {
      width: 34px; height: 34px;
      background: var(--ink);
      border-radius: 8px;
      display: grid;
      place-items: center;
    }

    .nav-logo-icon svg { width: 20px; height: 20px; fill: var(--gold); }

    .nav-logo-text {
      font-family: var(--font);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -.01em;
    }

    .nav-back {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 8px;
      text-decoration: none;
      font-size: .88rem;
      font-weight: 500;
      color: var(--ink-soft);
      transition: background .15s, color .15s;
    }

    .nav-back:hover { background: var(--cream); color: var(--ink); }

    /* ── TOOL HEADER ────────────────────────────────────────────────── */
    .tool-header {
      padding: 56px 0 40px;
      position: relative;
      z-index: 1;
    }

    .tool-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 12px;
    }

    .tool-tag-dot {
      width: 7px; height: 7px;
      background: var(--rose);
      border-radius: 50%;
    }

    .tool-header h1 {
      font-family: var(--font);
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -.02em;
      color: var(--ink);
      margin-bottom: 12px;
    }

    .tool-header p {
      font-size: 1rem;
      color: var(--ink-soft);
      max-width: 520px;
      line-height: 1.7;
    }

    /* ── FORM CARD ──────────────────────────────────────────────────── */
    .form-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
      position: relative;
      z-index: 1;
    }

    /* ── DROPZONE ───────────────────────────────────────────────────── */
    .dropzone {
      border: 2px dashed var(--border);
      border-radius: 10px;
      padding: 40px 24px;
      text-align: center;
      transition: border-color .2s, background .2s;
      cursor: pointer;
      position: relative;
    }

    .dropzone:hover,
    .dropzone--active {
      border-color: var(--rose);
      background: var(--rose-lt);
    }

    .dropzone-icon {
      width: 52px; height: 52px;
      background: var(--rose-lt);
      border-radius: 14px;
      display: grid;
      place-items: center;
      margin: 0 auto 16px;
    }

    .dropzone-icon svg { width: 26px; height: 26px; fill: var(--rose); }

    .dropzone-label {
      font-size: .95rem;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 4px;
    }

    .dropzone-sub {
      font-size: .83rem;
      color: var(--ink-soft);
      margin-bottom: 18px;
    }

    .btn-browse {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 20px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--page);
      font-size: .88rem;
      font-weight: 600;
      color: var(--ink);
      cursor: pointer;
      transition: background .15s, border-color .15s;
    }

    .btn-browse:hover { background: var(--cream); border-color: var(--ink-soft); }

    .file-input { display: none; }

    /* ── FILE LIST ──────────────────────────────────────────────────── */
    .list-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 28px 0 12px;
    }

    .list-title {
      font-size: .82rem;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }

    .list-hint {
      font-size: .78rem;
      color: #9e9c96;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .file-list-empty {
      padding: 20px;
      text-align: center;
      font-size: .88rem;
      color: #9e9c96;
      font-style: italic;
    }

    .file-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .file-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: var(--page);
      border: 1px solid var(--border);
      border-radius: 8px;
      transition: box-shadow .15s, border-color .15s;
    }

    .file-item:hover { border-color: #c8c4ba; box-shadow: 0 2px 8px var(--shadow); }

    .file-item--ghost {
      opacity: .4;
      background: var(--cream);
    }

    .drag-handle {
      color: #c0bdb5;
      cursor: grab;
      flex-shrink: 0;
      line-height: 0;
      transition: color .15s;
    }

    .drag-handle:active { cursor: grabbing; }
    .file-item:hover .drag-handle { color: var(--ink-soft); }

    .file-order {
      width: 22px; height: 22px;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: .75rem;
      font-weight: 700;
      color: var(--ink-soft);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .file-info {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    .file-name {
      font-size: .9rem;
      font-weight: 600;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .file-size {
      font-size: .78rem;
      color: #9e9c96;
      flex-shrink: 0;
    }

    .file-remove {
      width: 28px; height: 28px;
      border: none;
      background: none;
      border-radius: 6px;
      color: #c0bdb5;
      cursor: pointer;
      display: grid;
      place-items: center;
      flex-shrink: 0;
      transition: background .15s, color .15s;
    }

    .file-remove:hover { background: var(--rose-lt); color: var(--rose); }

    /* ── SUBMIT ─────────────────────────────────────────────────────── */
    .form-footer {
      margin-top: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .form-note {
      font-size: .8rem;
      color: #9e9c96;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .btn-submit {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      border-radius: 10px;
      border: none;
      background: var(--ink);
      color: var(--page);
      font-size: .95rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s, transform .15s, box-shadow .15s;
      box-shadow: 0 4px 18px var(--shadow);
    }

    .btn-submit:hover:not(:disabled) {
      background: var(--ink-soft);
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(26,26,46,.18);
    }

    .btn-submit:disabled {
      opacity: .45;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    /* ── FOOTER ─────────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 32px 0;
      margin-top: auto;
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .footer-copy { font-size: .83rem; color: #9e9c96; }

    @media (max-width: 600px) {
      .form-card { padding: 20px 16px; }
      .form-footer { flex-direction: column; align-items: stretch; }
      .btn-submit { justify-content: center; }
    }
  </style>
  {{ importmap('app') }}
</head>
<body>

<!-- NAV -->
<nav>
  <div class="container" style="max-width: 1120px;">
    <div class="nav-inner">
      <a href="{{ path('app_home') }}" class="nav-logo">
        <div class="nav-logo-icon">
          <svg viewBox="0 0 24 24"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h8l6-6V4a2 2 0 0 0-2-2H6zm0 2h12v10h-5a1 1 0 0 0-1 1v5H6V4zm7 11.5V18l2.5-2.5H13z"/></svg>
        </div>
        <span class="nav-logo-text">Book Tools</span>
      </a>
      <a href="{{ path('app_home') }}" class="nav-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        All tools
      </a>
    </div>
  </div>
</nav>

<!-- MAIN -->
<main>
  <div class="container">

    <!-- Header -->
    <div class="tool-header">
      <div class="tool-tag">
        <span class="tool-tag-dot"></span>
        Conversion
      </div>
      <h1>PDF to HTML</h1>
      <p>Upload one or more PDF files, arrange them in order, then convert them into clean HTML — ready to paste into your e-book or CMS.</p>
    </div>

    <!-- Form -->
    <div class="form-card">
      <form action="{{ path('app_tools_pdf_to_html_submit') }}"
            method="post"
            enctype="multipart/form-data"
            data-controller="pdf-upload"
            data-action="submit->pdf-upload#submit">

        <!-- Dropzone -->
        <div class="dropzone"
             data-pdf-upload-target="dropzone"
             data-action="dragover->pdf-upload#onDragOver dragleave->pdf-upload#onDragLeave drop->pdf-upload#onDrop">

          <div class="dropzone-icon">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM12 18l-4-4h2.5v-4h3v4H16l-4 4z"/></svg>
          </div>
          <div class="dropzone-label">Drop PDF files here</div>
          <div class="dropzone-sub">or browse your files — multiple files allowed</div>

          <label>
            <input type="file"
                   class="file-input"
                   accept=".pdf,application/pdf"
                   multiple
                   data-pdf-upload-target="input"
                   data-action="change->pdf-upload#onFileSelect">
            <span class="btn-browse">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Browse files
            </span>
          </label>
        </div>

        <!-- File list -->
        <div class="list-header">
          <span class="list-title">Files to convert</span>
          <span class="list-hint">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"/><polyline points="5 12 12 19 19 12"/>
            </svg>
            Drag to reorder
          </span>
        </div>

        <p class="file-list-empty" data-pdf-upload-target="empty">
          No files selected yet — add PDFs above.
        </p>

        <div class="file-list" data-pdf-upload-target="list" hidden></div>

        <!-- Submit -->
        <div class="form-footer">
          <span class="form-note">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Files are processed on the server and not stored
          </span>
          <button type="submit"
                  class="btn-submit"
                  data-pdf-upload-target="submit"
                  disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
            Convert to HTML
          </button>
        </div>

      </form>
    </div>

  </div>
</main>

<!-- FOOTER -->
<footer>
  <div class="container" style="max-width: 1120px;">
    <div class="footer-inner">
      <div class="footer-copy">© {{ "now"|date("Y") }} Book Tools — built for authors, by an author.</div>
    </div>
  </div>
</footer>

</body>
</html>
