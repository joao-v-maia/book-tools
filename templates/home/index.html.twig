<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book Tools — Digital Publishing Toolkit</title>
  <style>
    /* ── Reset & Base ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #1a1a2e;
      --ink-soft:  #3d3d5c;
      --page:      #faf9f6;
      --cream:     #f3f0e8;
      --gold:      #c9a84c;
      --gold-lt:   #e8d5a0;
      --teal:      #2d7d9a;
      --teal-lt:   #d4eef6;
      --rose:      #9b4f72;
      --rose-lt:   #f5dce9;
      --sage:      #4a7c59;
      --sage-lt:   #d4eadb;
      --amber:     #c07a3a;
      --amber-lt:  #fce8d0;
      --violet:    #5e4b8b;
      --violet-lt: #e5dff5;
      --border:    #e2ddd4;
      --shadow:    rgba(26,26,46,.10);
      --radius:    14px;
      --font:      'Georgia', 'Times New Roman', serif;
      --sans:      system-ui, -apple-system, 'Segoe UI', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--page);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Noise texture overlay ─────────────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 128px;
      opacity: .5;
    }

    /* ── Layout helpers ─────────────────────────────────────────────── */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

    /* ── NAV ────────────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(16px) saturate(180%);
      background: rgba(250,249,246,.88);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      gap: 24px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--ink);
    }

    .nav-logo-icon {
      width: 34px;
      height: 34px;
      background: var(--ink);
      border-radius: 8px;
      display: grid;
      place-items: center;
    }

    .nav-logo-icon svg { width: 20px; height: 20px; fill: var(--gold); }

    .nav-logo-text {
      font-family: var(--font);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -.01em;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
      list-style: none;
    }

    .nav-links a {
      padding: 6px 14px;
      border-radius: 8px;
      text-decoration: none;
      font-size: .88rem;
      font-weight: 500;
      color: var(--ink-soft);
      transition: background .15s, color .15s;
    }

    .nav-links a:hover {
      background: var(--cream);
      color: var(--ink);
    }

    .nav-cta {
      background: var(--ink) !important;
      color: var(--page) !important;
      padding: 7px 18px !important;
    }

    .nav-cta:hover { background: var(--ink-soft) !important; }

    /* ── HERO ───────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      overflow: hidden;
      padding: 100px 0 80px;
      text-align: center;
    }

    /* decorative blurs */
    .hero::before, .hero::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
      z-index: 0;
    }

    .hero::before {
      width: 560px; height: 400px;
      background: radial-gradient(ellipse, rgba(201,168,76,.18) 0%, transparent 70%);
      top: -80px; left: 50%;
      transform: translateX(-60%);
    }

    .hero::after {
      width: 420px; height: 320px;
      background: radial-gradient(ellipse, rgba(45,125,154,.14) 0%, transparent 70%);
      bottom: -40px; right: 10%;
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 5px 14px;
      font-size: .78rem;
      font-weight: 600;
      color: var(--ink-soft);
      letter-spacing: .04em;
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    .hero-badge-dot {
      width: 7px; height: 7px;
      background: var(--sage);
      border-radius: 50%;
    }

    .hero h1 {
      font-family: var(--font);
      font-size: clamp(2.6rem, 6vw, 4.4rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: var(--ink);
      max-width: 780px;
      margin: 0 auto 20px;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-sub {
      font-size: 1.12rem;
      color: var(--ink-soft);
      max-width: 520px;
      margin: 0 auto 36px;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 26px;
      border-radius: 10px;
      font-size: .95rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      text-decoration: none;
      transition: transform .15s, box-shadow .15s, background .15s;
    }

    .btn:hover { transform: translateY(-1px); }

    .btn-primary {
      background: var(--ink);
      color: var(--page);
      box-shadow: 0 4px 18px var(--shadow);
    }

    .btn-primary:hover { box-shadow: 0 8px 28px rgba(26,26,46,.18); }

    .btn-secondary {
      background: var(--cream);
      color: var(--ink);
      border: 1px solid var(--border);
    }

    .btn-secondary:hover { background: var(--border); }

    .hero-note {
      margin-top: 20px;
      font-size: .8rem;
      color: #9e9c96;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    /* ── STATS BAND ─────────────────────────────────────────────────── */
    .stats-band {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--cream);
      padding: 28px 0;
      margin-bottom: 80px;
    }

    .stats-grid {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
    }

    .stat { text-align: center; }

    .stat-value {
      font-family: var(--font);
      font-size: 2rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1;
    }

    .stat-label {
      font-size: .82rem;
      color: var(--ink-soft);
      margin-top: 4px;
    }

    /* ── SECTION ────────────────────────────────────────────────────── */
    section { padding: 80px 0; }

    .section-tag {
      display: inline-block;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 10px;
    }

    .section-title {
      font-family: var(--font);
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -.02em;
      color: var(--ink);
      margin-bottom: 14px;
    }

    .section-sub {
      font-size: 1rem;
      color: var(--ink-soft);
      max-width: 520px;
      line-height: 1.7;
    }

    .section-header { margin-bottom: 48px; }

    /* ── TOOLS GRID ─────────────────────────────────────────────────── */
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }

    .tool-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      cursor: pointer;
      transition: transform .18s, box-shadow .18s, border-color .18s;
      position: relative;
      overflow: hidden;
    }

    .tool-card::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity .2s;
      border-radius: inherit;
    }

    .tool-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px var(--shadow);
    }

    .tool-card:hover::before { opacity: 1; }

    /* color per card */
    .tool-card.teal   { --accent: var(--teal);  --accent-lt: var(--teal-lt);  }
    .tool-card.rose   { --accent: var(--rose);  --accent-lt: var(--rose-lt);  }
    .tool-card.sage   { --accent: var(--sage);  --accent-lt: var(--sage-lt);  }
    .tool-card.amber  { --accent: var(--amber); --accent-lt: var(--amber-lt); }
    .tool-card.violet { --accent: var(--violet);--accent-lt: var(--violet-lt);}
    .tool-card.gold   { --accent: var(--gold);  --accent-lt: var(--gold-lt);  }

    .tool-card:hover { border-color: var(--accent); }

    .tool-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      background: var(--accent-lt);
      display: grid;
      place-items: center;
      margin-bottom: 16px;
    }

    .tool-icon svg { width: 24px; height: 24px; fill: var(--accent); }

    .tool-badge {
      position: absolute;
      top: 20px; right: 20px;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      padding: 3px 8px;
      border-radius: 100px;
      background: var(--accent-lt);
      color: var(--accent);
    }

    .tool-title {
      font-family: var(--font);
      font-size: 1.12rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 6px;
    }

    .tool-desc {
      font-size: .88rem;
      color: var(--ink-soft);
      line-height: 1.6;
    }

    .tool-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 16px;
      font-size: .85rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
    }

    .tool-link:hover { text-decoration: underline; }

    /* ── PHILOSOPHY STRIP ────────────────────────────────────────────── */
    .philosophy {
      background: var(--ink);
      border-radius: 20px;
      padding: 64px 56px;
      color: var(--page);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
      margin: 80px 0;
    }

    .philosophy-label {
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .philosophy h2 {
      font-family: var(--font);
      font-size: 2rem;
      line-height: 1.25;
      letter-spacing: -.02em;
      margin-bottom: 16px;
    }

    .philosophy p {
      font-size: .95rem;
      color: rgba(250,249,246,.7);
      line-height: 1.75;
    }

    .principles {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .principle {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }

    .principle-icon {
      width: 40px; height: 40px;
      background: rgba(250,249,246,.08);
      border: 1px solid rgba(250,249,246,.12);
      border-radius: 10px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .principle-icon svg { width: 18px; height: 18px; fill: var(--gold); }

    .principle-title {
      font-weight: 700;
      font-size: .92rem;
      color: var(--page);
      margin-bottom: 3px;
    }

    .principle-desc {
      font-size: .83rem;
      color: rgba(250,249,246,.6);
      line-height: 1.6;
    }

    /* ── HOW IT WORKS ────────────────────────────────────────────────── */
    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    .how-step {
      text-align: center;
      padding: 0 16px;
    }

    .step-number {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--cream);
      border: 1px solid var(--border);
      font-family: var(--font);
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--ink);
      display: grid;
      place-items: center;
      margin: 0 auto 20px;
    }

    .how-step h3 {
      font-family: var(--font);
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .how-step p {
      font-size: .88rem;
      color: var(--ink-soft);
      line-height: 1.65;
    }

    /* ── FOOTER ─────────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 40px 0;
      margin-top: 80px;
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }

    .footer-copy {
      font-size: .83rem;
      color: #9e9c96;
    }

    .footer-links {
      display: flex;
      gap: 20px;
      list-style: none;
    }

    .footer-links a {
      font-size: .83rem;
      color: #9e9c96;
      text-decoration: none;
    }

    .footer-links a:hover { color: var(--ink); }

    /* ── Responsive ─────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .philosophy { grid-template-columns: 1fr; padding: 40px 28px; }
      .how-grid { grid-template-columns: 1fr; }
      .stats-grid { gap: 28px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="{{ path('app_home') }}" class="nav-logo">
        <div class="nav-logo-icon">
          <svg viewBox="0 0 24 24"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h8l6-6V4a2 2 0 0 0-2-2H6zm0 2h12v10h-5a1 1 0 0 0-1 1v5H6V4zm7 11.5V18l2.5-2.5H13z"/></svg>
        </div>
        <span class="nav-logo-text">Book Tools</span>
      </a>
      <ul class="nav-links">
        <li><a href="#tools">Tools</a></li>
        <li><a href="#how">How it works</a></li>
        <li><a href="#philosophy">Philosophy</a></li>
        <li><a href="#tools" class="nav-cta">Open Toolkit</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        No account required &nbsp;·&nbsp; No data stored
      </div>
      <h1>Your digital publishing<br>toolkit, <em>always at hand</em></h1>
      <p class="hero-sub">
        A curated collection of browser-based tools for authors,
        editors, and publishers. Everything runs locally in your browser —
        your manuscript never leaves your device.
      </p>
      <div class="hero-actions">
        <a href="#tools" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          Explore Tools
        </a>
        <a href="#how" class="btn btn-secondary">How it works</a>
      </div>
      <p class="hero-note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        100% client-side — your files stay private
      </p>
    </div>
  </div>
</section>

<!-- STATS BAND -->
<div class="stats-band">
  <div class="container">
    <div class="stats-grid">
      <div class="stat">
        <div class="stat-value">12+</div>
        <div class="stat-label">Publishing tools</div>
      </div>
      <div class="stat">
        <div class="stat-value">0 KB</div>
        <div class="stat-label">Data ever stored</div>
      </div>
      <div class="stat">
        <div class="stat-value">100%</div>
        <div class="stat-label">Client-side processing</div>
      </div>
      <div class="stat">
        <div class="stat-value">Free</div>
        <div class="stat-label">Always &amp; forever</div>
      </div>
    </div>
  </div>
</div>

<!-- TOOLS -->
<section id="tools">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Tools</span>
      <h2 class="section-title">Everything a publisher needs</h2>
      <p class="section-sub">
        Simple, focused utilities that handle the repetitive parts of digital
        publishing — so you can focus on the words.
      </p>
    </div>
    <div class="tools-grid">

      <!-- PDF to HTML -->
      <div class="tool-card rose">
        <div class="tool-badge">New</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM12 18l-4-4h2.5v-4h3v4H16l-4 4z"/></svg>
        </div>
        <div class="tool-title">PDF to HTML</div>
        <div class="tool-desc">Upload one or more PDFs, arrange them in order, and convert to clean HTML — ready for your e-book or CMS.</div>
        <a href="{{ path('tools.pdf-to-html') }}" class="tool-link">Open tool →</a>
      </div>

      <!-- Word Count -->
      <div class="tool-card teal">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 13h8v1.5H8V13zm0 3h8v1.5H8V16zm0-6h4v1.5H8V10z"/></svg>
        </div>
        <div class="tool-title">Word Count &amp; Stats</div>
        <div class="tool-desc">Paste your manuscript and get instant word, character, sentence, and paragraph counts — plus estimated reading time.</div>
        <a href="#" class="tool-link">Open tool →</a>
      </div>

      <!-- ToC Generator -->
      <div class="tool-card violet">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M3 9h14V7H3v2zm0 4h14v-2H3v2zm0 4h14v-2H3v2zm16 0h2v-2h-2v2zm0-10v2h2V7h-2zm0 6h2v-2h-2v2z"/></svg>
        </div>
        <div class="tool-title">Table of Contents Generator</div>
        <div class="tool-desc">Paste your manuscript headings and automatically generate a formatted TOC ready for copy-paste into your document.</div>
        <a href="#" class="tool-link">Open tool →</a>
      </div>

      <!-- Markdown Preview -->
      <div class="tool-card amber">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></svg>
        </div>
        <div class="tool-title">Markdown Preview</div>
        <div class="tool-desc">Write or paste Markdown and see a live, beautifully rendered preview. Export to HTML, styled for e-readers.</div>
        <a href="#" class="tool-link">Open tool →</a>
      </div>

      <!-- Readability -->
      <div class="tool-card rose">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M12 3C7 3 2.73 5.78 1 10c1.73 4.22 6 7 11 7s9.27-2.78 11-7c-1.73-4.22-6-7-11-7zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
        </div>
        <div class="tool-title">Readability Analyzer</div>
        <div class="tool-desc">Measure Flesch-Kincaid, Gunning Fog, and other readability scores to make sure your text lands at the right grade level.</div>
        <a href="#" class="tool-link">Open tool →</a>
      </div>

      <!-- Find & Replace -->
      <div class="tool-card sage">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        </div>
        <div class="tool-title">Smart Find &amp; Replace</div>
        <div class="tool-desc">Regex-powered find and replace for manuscripts. Preview changes before applying. Handles curly quotes, em-dashes, and more.</div>
        <a href="#" class="tool-link">Open tool →</a>
      </div>

      <!-- Metadata -->
      <div class="tool-card gold">
        <div class="tool-badge">Coming soon</div>
        <div class="tool-icon">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15v-4H7l5-8v4h4l-5 8z"/></svg>
